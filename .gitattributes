# Normalize line endings to LF in repository, checkout as-is on all platforms
* text=auto eol=lf

# Markdown files — always LF
*.md text eol=lf

# JSON files — always LF
*.json text eol=lf

# TypeScript/JavaScript — always LF
*.ts text eol=lf
*.js text eol=lf

# Shell scripts — always LF
*.sh text eol=lf

# Binary files — no conversion
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.zip binary
*.pdf binary
